# ============================================================
# skillbrew —— LLM 提供商配置（可插拔，换供应商只改这里，代码不动）
# 复制本文件为 .env 并填入你自己的 key。.env 已被 gitignore，不会进仓库。
# 分角色（D13）：文本组 / 视觉组 各自独立配置（D15 可插拔）
# ============================================================

# ---- 文本组：负责消化 / 执行计划 ----
# 推荐 DeepSeek（快、便宜）。拿 key：https://platform.deepseek.com → API keys
# 也可换 Agnes 文本模型：base_url=https://apihub.agnes-ai.com/v1  model=agnes-2.0-flash
TEXT_BASE_URL=https://api.deepseek.com
TEXT_API_KEY=sk-在这里填你的key
TEXT_MODEL=deepseek-chat

# ---- 视觉组：负责关键帧看图 ----
# 推荐 Agnes（免费 + OpenAI 兼容，实测真看图，但~5min/张靠限帧缓解）。
# 注册拿 key：https://platform.agnes-ai.com  （邮箱注册，无需绑卡/手机号）
# DeepSeek 官方 API 视觉暂未开放，故视觉组当前只能用 Agnes；后续官方开放后改这里即可切回。
VISION_BASE_URL=https://apihub.agnes-ai.com/v1
VISION_API_KEY=sk-在这里填你的key
VISION_MODEL=agnes-1.5-flash

# ---- 邮件通知（可选）：install --approve 完成后自动发 HTML 报告 ----
# 不配就不发、不报错。凭证只读 .env（不写死 QQ），换邮箱只改这里。
# MAIL_PROVIDER 命中预设 qq/163/gmail/outlook 即用预设服务器；留空则读下面 MAIL_HOST/PORT/USE_SSL 自定义。
# 授权码（不是登录密码）：QQ 在 设置→账户→SMTP 开关 拿；163/Gmail/Outlook 各自后台开 SMTP/应用专用密码。
MAIL_ADDRESS=
MAIL_AUTH_CODE=
MAIL_RECEIVER=          # 留空则默认发给自己（=MAIL_ADDRESS）
MAIL_PROVIDER=qq        # qq / 163 / gmail / outlook，或留空走下面自定义
# MAIL_HOST=smtp.example.com   # 仅 MAIL_PROVIDER 留空时生效
# MAIL_PORT=465                # 仅 MAIL_PROVIDER 留空时生效
# MAIL_USE_SSL=1               # 1=SSL(465) / 0=STARTTLS(587)

# ---- ASR（语音转文字）离线兜底（可选）----
# faster-whisper-small 首次会从 HuggingFace 下载（走 HF_ENDPOINT=hf-mirror.com 镜像）。
# 镜像拉不下来时：手动下好 Systran/faster-whisper-small 整个目录，把路径填这里走本地模型（不触发下载）。
# 不设也行——下载失败会报错+提醒+降级跳过（没字幕也能跑，质量打折）。
# WHISPER_MODEL_PATH=/path/to/faster-whisper-small
