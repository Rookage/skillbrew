# ============================================================
# skillbrew —— LLM 提供商配置（可插拔，换供应商只改这里，代码不动）
# 复制本文件为 .env 并填入你自己的 key。.env 已被 gitignore，不会进仓库。
# 分角色（D13）：文本组 / 视觉组 各自独立配置（D15 可插拔）
# ============================================================

# ---- 文本组：负责消化 / 执行计划 ----
# 推荐 DeepSeek（快、便宜）。拿 key：https://platform.deepseek.com → API keys
# 也可换 Agnes 文本模型：base_url=https://apihub.agnes-ai.com/v1  model=agnes-2.0-flash
TEXT_BASE_URL=https://api.deepseek.com
TEXT_API_KEY=sk-在这里填你的key
TEXT_MODEL=deepseek-chat

# ---- 视觉组：负责关键帧看图 ----
# 推荐 Agnes（免费 + OpenAI 兼容，实测真看图，但~5min/张靠限帧缓解）。
# 注册拿 key：https://platform.agnes-ai.com  （邮箱注册，无需绑卡/手机号）
# DeepSeek 官方 API 视觉暂未开放，故视觉组当前只能用 Agnes；后续官方开放后改这里即可切回。
VISION_BASE_URL=https://apihub.agnes-ai.com/v1
VISION_API_KEY=sk-在这里填你的key
VISION_MODEL=agnes-1.5-flash
